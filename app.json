{
  "expo": {
    "name": "Connor & Lumina",
    "slug": "connor-lumina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.connerlumina.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F7F4"
      },
      "package": "com.connerlumina.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "connor-lumina"
  }
}
